{
  "name": "@nova/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "nova": "bin/nova.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "echo \"cli runs via tsx in M1; nothing to build\"",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nova/context": "workspace:*",
    "@nova/core": "workspace:*",
    "@nova/observability": "workspace:*",
    "@nova/orchestration": "workspace:*",
    "@nova/runtime": "workspace:*",
    "@nova/safety": "workspace:*",
    "@nova/tools": "workspace:*",
    "cli-highlight": "^2.1.11",
    "commander": "^12.0.0",
    "ink": "^5.0.1",
    "react": "^18.3.0",
    "tsx": "^4.7.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0"
  }
}
