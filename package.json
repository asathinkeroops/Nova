{
  "name": "nova",
  "version": "0.1.0",
  "private": true,
  "description": "A terminal coding agent, deeply tuned for DeepSeek.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' run build",
    "dev": "tsx apps/cli/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
